{% comment %}
  Cart Drawer Upsell - Complementary Products
  Uses Search & Discovery app complementary products
  Custom Element: <sjm-cart-upsell>
{% endcomment %}

<!-- Wrapped in custom element <sjm-cart-upsell> -->
<style>
  cart-drawer-items {
    overflow: visible;
    border-bottom: 1px solid #D9DAD9;
  }
  /* Cart Drawer Upsell Styles */
  sjm-cart-upsell {margin-top: 1.5rem}
  sjm-cart-upsell .cart-drawer-upsell {
    padding: 1.5rem 0;      
  }

  sjm-cart-upsell .cart-drawer-upsell__header {
    margin-bottom: 1rem;
  }

  sjm-cart-upsell .cart-drawer-upsell__title {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #122023;
    text-align: center;
    text-transform: uppercase;
  }

  sjm-cart-upsell .price-atc--wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 5px;
  }

  sjm-cart-upsell .cart-drawer-upsell__content {
    position: relative;
  }

  /* Swiper Configuration */
  sjm-cart-upsell .cart-upsell-swiper {
    overflow: hidden;
    margin: 0 -0.5rem;
    padding: 0 0.5rem;
  }

  sjm-cart-upsell .cart-upsell-swiper .swiper-wrapper {
    align-items: stretch;
  }

  sjm-cart-upsell .cart-upsell-swiper .swiper-slide {
    height: auto;
    box-sizing: border-box;
  }

  /* Product Card */
  sjm-cart-upsell .cart-upsell__item {
    padding: 0.5rem;
  }

  sjm-cart-upsell .cart-upsell__product {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background-color: rgb(var(--color-background));
    border-radius: var(--buttons-radius, 0);
    border: 1px solid #122023;
    height: 100%;
    box-sizing: border-box;
  }

  sjm-cart-upsell .cart-upsell__image-wrapper {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    overflow: hidden;
    border-radius: var(--buttons-radius, 0);
    background-color: rgba(var(--color-foreground), 0.04);
  }

  sjm-cart-upsell .cart-upsell__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  sjm-cart-upsell .cart-upsell__image-wrapper:hover .cart-upsell__image {
    transform: scale(1.05);
  }

  sjm-cart-upsell .cart-upsell__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  sjm-cart-upsell .cart-upsell__product-title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    color: #122023;
    text-decoration: none;
    margin-bottom: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;    
  }

  sjm-cart-upsell .cart-upsell__product-title:hover {
    text-decoration: underline;
  }

    /* Price Styles */
  sjm-cart-upsell .cart-upsell__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  sjm-cart-upsell .cart-upsell__price .price-item--regular {
    font-size: 14px;
    font-weight: 700;
    color: #122023;
  }    

  /* Action Buttons */
  sjm-cart-upsell .cart-upsell__actions {
    margin-top: auto;
  }

  sjm-cart-upsell .cart-upsell__add-btn,
  sjm-cart-upsell .cart-upsell__select-btn {
    width: 100%;
    min-width: 75px !important;
    max-width: 75px !important;
    font-size: 14px;
    font-weight: 700;
    min-height: 3rem;
    background: #122023;
    color: #fff;
    cursor: pointer;
    padding-inline: 0;
    transition: background-color 0.2s ease, opacity 0.2s ease;
  }

  sjm-cart-upsell .cart-upsell__add-btn:disabled,
  sjm-cart-upsell .cart-upsell__select-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  sjm-cart-upsell .cart-upsell__add-btn.is-loading {
    position: relative;
    color: transparent;
  }

  sjm-cart-upsell .cart-upsell__add-btn.is-loading::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1.6rem;
    height: 1.6rem;
    margin: -0.8rem 0 0 -0.8rem;
    border: 2px solid rgba(var(--color-foreground), 0.3);
    border-top-color: rgb(var(--color-foreground));
    border-radius: 50%;
    animation: upsell-spin 0.8s linear infinite;
  }

  @keyframes upsell-spin {
    to { transform: rotate(360deg); }
  }

  /* Variant Selector */
  sjm-cart-upsell .cart-upsell__variants {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    animation: slideDown 0.3s ease;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  sjm-cart-upsell .cart-upsell__variants-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    max-height: 150px;
    overflow-y: auto;
  }

  sjm-cart-upsell .cart-upsell__variant-option {
    flex: 0 0 auto;
  }

  sjm-cart-upsell .cart-upsell__variant-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    font-size: 1.2rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: var(--buttons-radius, 0);
    cursor: pointer;
    transition: all 0.2s ease;
    background-color: rgb(var(--color-background));
    min-width: 40px;
    text-align: center;
  }

  sjm-cart-upsell .cart-upsell__variant-label:hover {
    border-color: rgba(var(--color-foreground), 0.5);
  }

  sjm-cart-upsell .cart-upsell__variant-input:checked + .cart-upsell__variant-label {
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border-color: rgb(var(--color-foreground));
  }

  sjm-cart-upsell .cart-upsell__variant-input:disabled + .cart-upsell__variant-label {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  sjm-cart-upsell .cart-upsell__add-variant-btn {
    width: 100%;
    padding: 0.6rem 1rem;
    font-size: 1.2rem;
    min-height: 3.6rem;
  }

  /* Navigation Buttons */
  sjm-cart-upsell .cart-upsell-navigation {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  sjm-cart-upsell .cart-upsell-button-prev,
  sjm-cart-upsell .cart-upsell-button-next {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 50%;
    background-color: rgb(var(--color-background));
    cursor: pointer;
    transition: all 0.2s ease;
  }

  sjm-cart-upsell .cart-upsell-button-prev:hover,
  sjm-cart-upsell .cart-upsell-button-next:hover {
    background-color: rgba(var(--color-foreground), 0.05);
    border-color: rgba(var(--color-foreground), 0.4);
  }

  sjm-cart-upsell .cart-upsell-button-prev:disabled,
  sjm-cart-upsell .cart-upsell-button-next:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  sjm-cart-upsell .cart-upsell-button-prev .icon-caret {
    transform: rotate(90deg);
  }

  sjm-cart-upsell .cart-upsell-button-next .icon-caret {
    transform: rotate(-90deg);
  }

  sjm-cart-upsell .cart-upsell-button-prev .icon-caret,
  sjm-cart-upsell .cart-upsell-button-next .icon-caret {
    width: 1rem;
    height: 1rem;
  }

  /* Loading State */
  sjm-cart-upsell .cart-drawer-upsell[data-loading="true"] .cart-upsell-swiper {
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  sjm-cart-upsell .cart-drawer-upsell__loader {
    width: 3rem;
    height: 3rem;
    border: 3px solid rgba(var(--color-foreground), 0.1);
    border-top-color: rgb(var(--color-foreground));
    border-radius: 50%;
    animation: upsell-spin 0.8s linear infinite;
  }

  sjm-cart-upsell .swiper-pagination {
    position: relative!important;
    bottom: 0 !important;
  }

  sjm-cart-upsell .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    background: white;
    opacity: 1;
    border: 1.5px solid #122023;
  }
  sjm-cart-upsell .swiper-pagination-bullet-active {
    background: #122023;
  }

  /* Empty State */
  sjm-cart-upsell .cart-drawer-upsell[data-empty="true"] {
      display: none;
  }

  /* Responsive */
  @media screen and (max-width: 749px) {
    sjm-cart-upsell .cart-drawer-upsell {
      padding: 1rem;
    }
    
    sjm-cart-upsell .cart-upsell__image-wrapper {
      width: 70px;
      height: 70px;
    }
  }
</style>
<sjm-cart-upsell class="cart-drawer-upsell" style="display: none;">
  <div class="cart-drawer-upsell__header">
    <h3 class="cart-drawer-upsell__title h4">{{ 'cart.upsell.title' | t | default: 'You may also like' }}</h3>
  </div>
  
  <div class="cart-drawer-upsell__content">
    <div class="swiper cart-upsell-swiper">
      <div class="swiper-wrapper" data-upsell-products></div>
    </div>
    
    <div class="cart-upsell-navigation">
      <div class="swiper-pagination"></div>
    </div>
  </div>
</sjm-cart-upsell>

{% comment %} Upsell Product Card Template {% endcomment %}
<template id="upsell-product-template">
  <div class="swiper-slide cart-upsell__item" data-upsell-item>
    <div class="cart-upsell__product">
      <a class="cart-upsell__image-wrapper" href="" data-upsell-link>
        <img 
          class="cart-upsell__image" 
          src="/placeholder.svg"
          alt=""
          data-upsell-image
          loading="lazy"
          width="100"
          height="100"
        >
      </a>
      
      <div class="cart-upsell__details">
        <a href="" class="cart-upsell__product-title" data-upsell-title></a>
        
        <div class="price-atc--wrapper">
            <div class="cart-upsell__price" data-upsell-price>
                <span class="price-item price-item--regular" data-regular-price></span>                
            </div>
            
            <div class="cart-upsell__actions">
                <button 
                    type="button" 
                    class="cart-upsell__add-btn button button--secondary"
                    data-upsell-add-btn
                    data-variant-id=""
                >
                    {{ 'cart.upsell.add' | t | default: 'Add' }}
                </button>
            
                <button 
                    type="button" 
                    class="cart-upsell__select-btn button button--secondary"
                    data-upsell-select-btn
                    style="display: none;"
                >
                    {{ 'cart.upsell.select_options' | t | default: 'Select Options' }}
                </button>
            </div>
        </div>
        
        <div class="cart-upsell__variants" data-upsell-variants style="display: none;">
          <div class="cart-upsell__variants-wrapper" data-variants-wrapper></div>
          <button 
            type="button" 
            class="cart-upsell__add-variant-btn button button--primary"
            data-add-selected-variant
            disabled
          >
            {{ 'cart.upsell.add_selected' | t | default: 'Add Selected' }}
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<template id="upsell-variant-template">
  <div class="cart-upsell__variant-option">
    <input 
      type="radio" 
      name="" 
      id="" 
      value=""
      class="cart-upsell__variant-input visually-hidden"
      data-variant-input
    >
    <label for="" class="cart-upsell__variant-label" data-variant-label></label>
  </div>
</template>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="{{ 'cart-drawer-upsell.js' | asset_url }}"></script>
